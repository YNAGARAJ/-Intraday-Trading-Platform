# App 2 (Australia) -- local overrides only. See the repo-root .env.example for the full,
# documented variable list across every module. Copy this file to .env in apps/australia/ (or set
# these in the environment directly) for Australia-specific deployment overrides. Zero real values.

ENVIRONMENT=development
LOG_LEVEL=INFO
TRADING_MODE=PAPER
LIVE_TRADING_CONFIRMED=false

REDIS_URL=redis://localhost:6379/1
POSTGRES_DSN=postgresql://trading:trading@localhost:5432/trading
TIMESCALE_DSN=postgresql://trading:trading@localhost:5433/trading_ts
