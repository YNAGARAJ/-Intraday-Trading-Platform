# Repo-root .env.example -- documents every environment variable referenced anywhere in
# MASTER_BUILD_PROMPT_FINAL.MD, grouped by the module that owns/consumes it. Zero real values.
# Copy to .env and fill in for local development; .env is gitignored. Variables not yet consumed
# by any built module (most of this file, as of M01) are documented for discoverability but are
# not yet validated by shared.core.config.Settings -- each owning module adds its own fields to
# Settings when it's built, per CLAUDE.md's "durable coding conventions".

# ============================================================================
# M01 -- Project Scaffold & Config (consumed by shared.core.config.Settings today)
# ============================================================================
APP_ID=                            # "india" | "australia" -- normally set in code, not env
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# RULE 1: paper trading is ALWAYS the default. LIVE requires BOTH of the next two vars set
# explicitly -- see Settings.is_live_trading_enabled. Never set TRADING_MODE=LIVE as a default
# in any committed file.
TRADING_MODE=PAPER                 # PAPER | LIVE
LIVE_TRADING_CONFIRMED=false       # true | false

REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=postgresql://trading:trading@localhost:5432/trading
TIMESCALE_DSN=postgresql://trading:trading@localhost:5433/trading_ts

# ============================================================================
# M03 -- High-Throughput Buffering & Storage
# ============================================================================
SQLITE_BUFFER_PATH=shared/data/buffer.db

# ============================================================================
# M13 -- Compliance & Regulatory Engine (India / SEBI)
# ============================================================================
USE_GENERIC_ALGO_ID=false          # true routes orders under the broker-provided generic algo ID
STRATEGY_ID_EMA_VWAP_TREND=
STRATEGY_ID_ORB_BREAKOUT=
STRATEGY_ID_MOMENTUM_RSI=
STRATEGY_ID_MEAN_REVERT_PIVOT=
STRATEGY_ID_ORDER_FLOW_ABSORPTION=

# ============================================================================
# M15 -- Authentication & Token Manager
# ============================================================================
# Zerodha Kite Connect (India)
KITE_API_KEY=
KITE_API_SECRET=
KITE_TOTP_SECRET=
KITE_AWS_ELASTIC_IP=                # must be registered in Kite Developer Portal before any live order

# Interactive Brokers TWS (Australia)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                      # 7497 = paper account, 7496 = live -- never hardcode in code
IBKR_CLIENT_ID=

# ============================================================================
# M10 -- Sentiment & News Agent / LLM cost optimisation (LiteLLM routing)
# ============================================================================
GROQ_API_KEY=
ANTHROPIC_API_KEY=
SENTIMENT_MODEL=groq/llama-3.1-8b-instant
REASONING_MODEL=groq/llama-3.3-70b-versatile
SUMMARY_MODEL=groq/llama-3.3-70b-versatile
COMPLEX_MODEL=claude-sonnet-4-6

# ============================================================================
# M20 -- Alerting & Notification
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ============================================================================
# M22 -- Dashboard & API
# ============================================================================
API_KEY=                            # protects POST /api/v1/controls/kill and other control routes

# ============================================================================
# M23 -- Docker & Cloud Deployment
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_INDIA=ap-south-1
AWS_REGION_AUSTRALIA=ap-southeast-2
